#: data/jorts.desktop.in.in:5 data/jorts.metainfo.xml.in.in:9
msgid "Jorts"
msgstr "Jorts"

#: data/jorts.desktop.in.in:6 data/jorts.metainfo.xml.in.in:49
msgid "Sticky notes"
msgstr "Notas adhesivas"

#: data/jorts.desktop.in.in:7 data/jorts.metainfo.xml.in.in:10
msgid "Write on colourful little squares"
msgstr "Escribe en cuadraditos de colores"

#: data/jorts.desktop.in.in:13
msgid "text;plain;plaintext;notepad;notes;sticky;post-it;"
msgstr "texto;sin formato;texto sin formato;bloc;notas;adhesivo;post-it;"

#: data/jorts.desktop.in.in:18
msgid "New sticky note"
msgstr "Nueva nota adhesiva"

#: data/jorts.desktop.in.in:23
msgid "Show Preferences"
msgstr "Mostrar preferencias"

#: data/jorts.metainfo.xml.in.in:12
msgid ""
"Neither jeans nor shorts, just like jorts! A thoughtful little sticky notes "
"application, to display any sort of short term information on your screen."
msgstr ""

#: data/jorts.metainfo.xml.in.in:13
msgid "Features include:"
msgstr "Las características incluyen:"

#: data/jorts.metainfo.xml.in.in:15
msgid "Colourful: Eleven pretty pastel themes"
msgstr "Colorido: Once bonitos temas en tonos pastel"

#: data/jorts.metainfo.xml.in.in:16
msgid "Cute: Each new note has a funny or cute random (editable) title"
msgstr ""
"Simpático: Cada nota nueva tiene un divertido título aleatorio (editable)"

#: data/jorts.metainfo.xml.in.in:17
msgid "Thoughtful: Jorts does its best to be comfortable to use, always!"
msgstr ""

#: data/jorts.metainfo.xml.in.in:18
#, fuzzy
msgid "Private: Try the scribbles mode!"
msgstr "Privado: ¡Prueba el modo borroneo!"

#: data/jorts.metainfo.xml.in.in:20
msgid ""
"Windows installers are also available, and require no admin rights. So you "
"can even use this at work!"
msgstr ""

#: data/jorts.metainfo.xml.in.in:21
msgid "This app is made lovingly and without any LLM intervention."
msgstr ""

#: data/jorts.metainfo.xml.in.in:33
msgid "Lainsce + Stella and Charlie"
msgstr "Lainsce + Stella y Charlie"

