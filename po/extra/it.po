#~ msgid "Fixed blurrinness in high-scaled display"
#~ msgstr ""
#~ "Risolto il problema della sfocatura nella visualizzazione ad alta scala"

#~ msgid "Added high-resolution screenshots"
#~ msgstr "Aggiunti screenshot ad alta risoluzione"

