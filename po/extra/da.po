#: data/jorts.desktop.in.in:6 data/jorts.metainfo.xml.in.in:49
msgid "Sticky notes"
msgstr "Sticky notes"

#: data/jorts.desktop.in.in:7
msgid ""
"Write down notes, reminders, random thoughts and other short-term "
"informations"
msgstr ""
"Skriv noter, påmindelser, tilfældige tanker og andre kortvarige "
"informationer ned."

#: data/jorts.desktop.in.in:13
msgid "text;plain;plaintext;notepad;notes;sticky;post-it;"
msgstr ""
"tekst;almindelig;almindelig tekst;notesblok;noter;klistermærke;post-it;"

